{
    "tasks": [
      {
        "type": "cppbuild", // C/C++: g++.exe 生成活动文件
        "label": "C/C++: g++.exe 生成活动文件", // C/C++: g++.exe 生成活动文件
        "command": "g++.exe", // g++.exe
        "args": [ //  参数
          "-fdiagnostics-color=always",  // g++.exe -fdiagnostics-color=always
          "-g", // 生成可执行文件
          "-fexec-charset=GBK",   // 处理mingw中文编码问题
          "-finput-charset=UTF-8",// 处理mingw中文编码问题
          "${file}", // 源文件
          "-o", // 输出文件
          "${fileDirname}\\${fileBasenameNoExtension}.exe" // 输出文件
        ],
        "options": {
          "cwd": "${fileDirname}"  // 输出文件所在目录
        },
        "problemMatcher": [
          "$gcc"  // gcc
        ],
        "group": {
          "kind": "build", // 构建
          "isDefault": true  // 默认
        },
        "detail": "调试器生成的任务。"  
      }
    ],
    "version": "2.0.0"
  }
  